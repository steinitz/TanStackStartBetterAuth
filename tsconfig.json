{
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "strictNullChecks": true,
		// absolute file paths from the app directory e.g. ~/routes
		"baseUrl": ".",
		"paths": {
			"~/*": ["app/*"]
		}
  },
}

